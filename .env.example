NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
API_ORIGIN=http://localhost:4000
TRUST_PROXY=false
TRUSTED_ORIGINS=http://localhost:5173
VITE_API_ORIGIN=http://localhost:4000
BODY_LIMIT_BYTES=1048576

POSTGRES_USER=app
POSTGRES_PASSWORD=app-development-only
POSTGRES_DB=app
POSTGRES_PORT=5432
DATABASE_URL=postgresql://app:app-development-only@localhost:5432/app
TEST_DATABASE_URL=postgresql://app:app-development-only@localhost:5432/app_test

S3MOCK_PORT=9090
S3_ENDPOINT=http://localhost:9090
S3_REGION=us-east-1
S3_BUCKET=wakyak-attachments
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true

BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:4000
SITE_OWNER_EMAIL=owner@example.com
ANONYMITY_SECRET=replace-with-at-least-32-random-characters
INVITATION_COOKIE_SECRET=replace-with-another-32-character-secret
SESSION_EXPIRES_IN_SECONDS=604800
SESSION_UPDATE_AGE_SECONDS=86400

GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

EMAIL_MODE=console
BREVO_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
