{
  "name": "wakyak",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:apps": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "test:integration": "pnpm --filter @wakyak/api test:integration",
    "db:generate": "pnpm --filter @wakyak/database db:generate",
    "db:migrate": "pnpm --filter @wakyak/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @wakyak/database db:migrate:deploy",
    "db:studio": "pnpm --filter @wakyak/database db:studio",
    "db:reset": "pnpm --filter @wakyak/database db:reset"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.13",
    "auth": "1.6.23",
    "eslint": "^9.39.2",
    "prettier": "^3.9.0",
    "turbo": "^2.10.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.54.0"
  }
}
